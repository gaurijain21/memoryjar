rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /groups/{groupId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid in firestore.get(
          /databases/(default)/documents/groups/$(groupId)
        ).data.memberIds;
    }

    match /publicMemories/{publicMemoryId}/{allPaths=**} {
      allow read: if true;
      // Public image writes happen before the public Firestore mirror exists,
      // so authorize by the uid prefix in {uid}_{memoryId}.
      allow write: if request.auth != null
        && publicMemoryId.matches(request.auth.uid + "_.*");
    }
  }
}
