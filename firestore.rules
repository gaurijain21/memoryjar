rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isGroupMember(groupId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    function isGroupOwner(groupId) {
      return signedIn()
        && get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid;
    }

    function onlyGroupMembershipChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "memberIds",
        "members"
      ]);
    }

    function isJoiningSelf() {
      return signedIn()
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.members[request.auth.uid].uid == request.auth.uid;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      allow read: if signedIn();

      allow update: if signedIn()
        && request.resource.data.ownerId == resource.data.ownerId
        && resource.data.ownerId in request.resource.data.memberIds
        && onlyGroupMembershipChanged()
        && (
          resource.data.ownerId == request.auth.uid
          || isJoiningSelf()
        );

      allow delete: if isGroupOwner(groupId);

      match /memories/{memoryId} {
        allow read, write: if isGroupMember(groupId);
      }
    }

    match /memoryLocationAggregates/{aggregateId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.keys().hasOnly([
          "lat",
          "lng",
          "locationName",
          "locationSource",
          "placeId",
          "placeName",
          "formattedAddress",
          "placePhotoReference",
          "count",
          "createdAt",
          "updatedAt"
        ]);
    }
  }
}
