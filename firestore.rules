rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isGroupMember(groupId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    function isGroupOwner(groupId) {
      return signedIn()
        && get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      allow read: if signedIn();
      allow update: if isGroupOwner(groupId);
      allow update: if signedIn()
        && request.resource.data.ownerId == resource.data.ownerId
        && (
          request.auth.uid in resource.data.memberIds
          || request.auth.uid in request.resource.data.memberIds
        );
      allow delete: if isGroupOwner(groupId);

      match /memories/{memoryId} {
        allow read, write: if isGroupMember(groupId);
      }
    }

    match /memoryLocationAggregates/{aggregateId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.keys().hasOnly([
          "lat",
          "lng",
          "locationName",
          "locationSource",
          "placeId",
          "placeName",
          "formattedAddress",
          "placePhotoReference",
          "count",
          "publicCount",
          "privateCount",
          "groupCount",
          "createdAt",
          "updatedAt",
          "deletedAt"
        ]);
    }

    match /publicMemories/{memoryId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.audience == "public";
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /memoryReactions/{reactionId} {
      function canReadReaction() {
        return resource.data.visibility == "public"
          || (signedIn() && resource.data.ownerId == request.auth.uid)
          || (signedIn() && resource.data.groupId is string && isGroupMember(resource.data.groupId));
      }

      function canWriteReaction() {
        return request.resource.data.visibility == "public"
          || (signedIn() && request.resource.data.ownerId == request.auth.uid)
          || (signedIn() && request.resource.data.groupId is string && isGroupMember(request.resource.data.groupId));
      }

      allow read: if true;
      allow create, update: if signedIn() && canWriteReaction();

      match /emojiUsers/{reactionUserId} {
        function parentData() {
          return get(/databases/$(database)/documents/memoryReactions/$(reactionId)).data;
        }

        function canAccessParent() {
          return parentData().visibility == "public"
            || parentData().ownerId == request.auth.uid
            || (parentData().groupId is string && isGroupMember(parentData().groupId));
        }

        allow read: if signedIn() && canAccessParent();
        allow create, delete: if signedIn()
          && reactionUserId.matches(".*_" + request.auth.uid)
          && canAccessParent();
      }
    }
  }
}
